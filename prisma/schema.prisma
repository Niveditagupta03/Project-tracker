generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Project {
  id             Int      @id @default(autoincrement())
  title          String
  description    String?
  type           String?
  owner          String?
  status         String?
  startDate      DateTime?
  endDate        DateTime?
  uatDate        DateTime?
  prodDate       DateTime?
  dependencyWith String?
  comments       String?
  progress       Int?      @default(0)
  priority       String?   @default("Medium")
  health         String?   @default("On Track")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Activity {
  id          Int      @id @default(autoincrement())
  userName    String
  userRole    String
  actionType  String
  details     String
  createdAt   DateTime @default(now())
}

